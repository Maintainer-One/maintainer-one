---
import '../styles/global.css';
import Countdown from '../components/Countdown.svelte';
import BrandLogo from '$lib/components/BrandLogo.svelte';
import MultiViewShowcase from '../components/MultiViewShowcase.svelte';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || Deno.env.get("PUBLIC_SUPABASE_URL");
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || Deno.env.get("PUBLIC_SUPABASE_ANON_KEY");

if (!supabaseUrl) {
	console.error("Supabase environment variables are missing!");
	console.log("import.meta.env:", import.meta.env);
}

const supabase = createClient(supabaseUrl, supabaseKey);

const { data: teams } = await supabase
	.from('teams')
	.select('id, name, color, logo_icon_url')
	.order('name', { ascending: true });
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Maintainer One</title>
	</head>
	<body class="bg-[var(--color-background-dark)] text-white font-sans antialiased overflow-x-hidden min-h-screen relative">
		
		<div class="relative z-10 min-h-[90vh] flex flex-col items-center justify-center bg-gradient-to-b from-black/80 via-black/40 to-transparent px-4">
			<div class="max-w-4xl mx-auto text-center flex flex-col items-center">
				<div class="mb-6 drop-shadow-2xl hover:scale-105 transition-transform duration-500">
					<BrandLogo size="w-24 h-24 md:w-32 md:h-32" />
				</div>
				<h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white uppercase leading-none drop-shadow-2xl mb-4">
					Maintainer <span class="text-[var(--color-brand-primary)]">One</span>
				</h1>
				
				<p class="text-sm md:text-lg text-[var(--color-brand-primary)] font-black uppercase tracking-[0.4em] mb-12 drop-shadow-lg">
					The sports sim powered by open source logic.
				</p>
				
				<p class="text-xl md:text-2xl text-white/80 font-bold max-w-2xl mx-auto mb-8 drop-shadow-lg leading-relaxed">
					Code. Community. Championships.
				</p>

				<!-- Countdown to Season 1 -->
				<div class="mb-12 glass-panel p-6 md:p-8 rounded-2xl border-white/5 bg-black/20 backdrop-blur-md">
					<p class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--color-brand-primary)]">Alpha 1 Launch</p>
					<p class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--color-brand-primary)] mb-6">September 5th 2026 @ 12pm PDT</p>
					<Countdown targetDate="2026-09-05T19:00:00Z" client:load />
				</div>

				<div class="flex flex-col sm:flex-row items-center justify-center gap-6">
					<div class="w-full sm:w-auto px-10 py-5 bg-white/5 text-white/20 text-sm md:text-base font-black uppercase tracking-[0.2em] rounded-xl border border-white/10 cursor-not-allowed flex items-center gap-3 group relative overflow-hidden">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						<div class="relative h-5 flex items-center overflow-hidden">
							<span class="block group-hover:-translate-y-full transition-transform duration-300">The Dashboard</span>
							<span class="absolute inset-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 whitespace-nowrap text-[var(--color-brand-primary)]">Coming Soon</span>
						</div>
						<span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></span>
					</div>
					<a href="https://github.com/Maintainer-One/maintainer-one" class="w-full sm:w-auto px-10 py-5 bg-[var(--color-brand-primary)] hover:bg-emerald-400 text-black text-sm md:text-base font-black uppercase tracking-[0.2em] rounded-xl shadow-[0_0_30px_rgba(5,150,105,0.2)] transition-all hover:scale-105 hover:shadow-[0_0_50px_rgba(5,150,105,0.4)]">
						Join the Community
					</a>
				</div>
			</div>
		</div>

		<!-- The Pitch -->
		<section class="relative z-10 py-32 px-4 bg-[var(--color-background-deeper)]/80 backdrop-blur-md border-y border-white/5">
			<div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8 pb-16">
				<div class="glass-panel p-10 rounded-2xl hover:border-emerald-500/30 transition-all group">
					<div class="text-[var(--color-brand-primary)] mb-8 transform group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
					</div>
					<h3 class="text-3xl font-black uppercase tracking-tighter mb-4 text-[var(--color-brand-secondary)]">Code</h3>
					<p class="text-white/60 leading-relaxed font-medium">
						At its heart, Maintainer One is a coding game where all logic and decisions are automated through code. Each league has an evolving protocol that determines the rules and constraints each team plays under.
					</p>
				</div>
				
				<div class="glass-panel p-10 rounded-2xl hover:border-emerald-500/30 transition-all group">
					<div class="text-[var(--color-brand-primary)] mb-8 transform group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
					</div>
					<h3 class="text-3xl font-black uppercase tracking-tighter mb-4 text-[var(--color-brand-secondary)]">Community</h3>
					<p class="text-white/60 leading-relaxed font-medium">
						Open source and community driven. The maintainers for each team foster a strong community of contributors to develop the most robust logic and gameplans to adapt to an evolving protocol.
					</p>
				</div>
				
				<div class="glass-panel p-10 rounded-2xl hover:border-emerald-500/30 transition-all group">
					<div class="text-[var(--color-brand-primary)] mb-8 transform group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
					</div>
					<h3 class="text-3xl font-black uppercase tracking-tighter mb-4 text-[var(--color-brand-secondary)]">Championships</h3>
					<p class="text-white/60 leading-relaxed font-medium">
						Only one team can win each season. The maintainer of that team will be awarded the Maintainer One title, cementing their legacy in the history of the league.
					</p>
				</div>
			</div>
		<!-- Teams Showcase -->
		<section class="relative z-10 py-32 px-4 overflow-hidden bg-black/20">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-4">The <span class="text-[var(--color-brand-primary)]">Founding</span> Teams</h2>
					<p class="text-xl text-white/40 font-medium uppercase tracking-widest">The inaugural franchises are recruiting. Find your community and define their strategy.</p>
				</div>

				<div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
					{teams?.map((team) => (
						<div class="glass-panel p-8 rounded-2xl border-white/5 bg-white/5 hover:border-white/20 transition-all group text-center flex flex-col items-center justify-center gap-6">
							<div 
								class="size-20 rounded-xl flex items-center justify-center text-3xl shadow-xl transition-transform group-hover:scale-110"
								style={`background-color: ${team.color}15; border: 1px solid ${team.color}40; color: ${team.color}`}
							>
								{team.logo_icon_url ? (
									<img src={team.logo_icon_url} alt={team.name} class="size-12 object-contain" />
								) : (
									<span class="font-black">{team.name[0]}</span>
								)}
							</div>
							<div class="flex flex-col gap-3">
								<h4 class="text-sm font-black uppercase tracking-widest text-white group-hover:text-[var(--color-brand-primary)] transition-colors line-clamp-1">{team.name}</h4>
								<div class="flex flex-col gap-1.5 opacity-60 group-hover:opacity-100 transition-opacity">
									<div class="flex items-center justify-center gap-2">
										<span class="size-1 rounded-full bg-emerald-500 animate-pulse"></span>
										<span class="text-[7px] font-black uppercase tracking-[0.2em] text-emerald-500">Seeking Maintainers</span>
									</div>
									<div class="flex items-center justify-center gap-2">
										<span class="size-1 rounded-full bg-emerald-500/50"></span>
										<span class="text-[7px] font-black uppercase tracking-[0.2em] text-white/50">Seeking Contributors</span>
									</div>
									<div class="flex items-center justify-center gap-2">
										<span class="size-1 rounded-full bg-emerald-500/50"></span>
										<span class="text-[7px] font-black uppercase tracking-[0.2em] text-white/50">Seeking Fans</span>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Multi-View Showcase -->
		<MultiViewShowcase client:load />

		<!-- Join the Community -->
		<section class="relative z-10 py-16 px-4 bg-black/40 backdrop-blur-sm">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-8">Join the <span class="text-[var(--color-brand-primary)]">Community</span></h2>
				<p class="text-xl text-white/60 mb-16 max-w-2xl mx-auto font-medium">
					Maintainer One is open source and community-driven. Whether you're a developer, a strategist, or a fan, there's a place for you in the league.
				</p>

				<div class="grid sm:grid-cols-2 gap-6 text-left">
					<a href="https://github.com/Maintainer-One/maintainer-one" class="glass-panel p-8 rounded-2xl hover:border-white/20 transition-all group">
						<h4 class="text-lg font-black uppercase tracking-widest mb-3 text-[var(--color-brand-primary)] group-hover:text-emerald-400">Contribute</h4>
						<p class="text-white/40 text-sm leading-relaxed">
							Submit PRs, fix bugs, and help build the foundation before the next season begins.
						</p>
					</a>
					<a href="https://github.com/Maintainer-One/maintainer-one/issues" class="glass-panel p-8 rounded-2xl hover:border-white/20 transition-all group">
						<h4 class="text-lg font-black uppercase tracking-widest mb-3 text-[var(--color-brand-primary)] group-hover:text-emerald-400">Design</h4>
						<p class="text-white/40 text-sm leading-relaxed">
							Have an idea for a game mechanic or found a loop-hole in the protocol? Join the conversation on GitHub.
						</p>
					</a>
				</div>
			</div>
		</section>

		<footer class="relative z-10 py-12 px-4 border-t border-white/5 text-center">
			<p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20">
				Maintainer One &bull; 2026
			</p>
		</footer>

	</body>
</html>
